# ============================================================
# ENVIRONMENT VARIABLES - Salin file ini menjadi .env
# dan sesuaikan nilainya dengan konfigurasi lokal Anda
# ============================================================

# Database MySQL
DB_HOST=localhost
DB_PORT=3306
DB_NAME=skincare_overclaim
DB_USER=root
DB_PASSWORD=your_password_here

# App Secret Key (ganti dengan string acak yang kuat)
SECRET_KEY=your-super-secret-key-change-this-in-production

# App Config
APP_NAME=NeuroFuzzy Skincare Overclaim Detector
APP_VERSION=1.0.0
DEBUG=False
